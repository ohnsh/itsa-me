---
import platforms from './platforms'

interface Props {
  platform: keyof typeof platforms
  handle: string
}

const { platform, handle } = Astro.props
const { Icon, link, display } = platforms[platform]
---

<li><a href={link(handle)}><Icon stroke-width="1" /><span>{display(handle)}</span></a></li>

<style>
  a {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1em;
    padding: 0.5em 1em;
    color: inherit;
    text-decoration: none;
  }
</style>
